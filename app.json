{
  "expo": {
    "name": "مواقيت | أذكار السنة",
    "slug": "mawaqeet-adhkar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A5C38"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mawaqeet.adhkar"
    },
    "android": {
      "package": "com.mawaqeet.adhkar",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-av"
    ]
  }
}
      
